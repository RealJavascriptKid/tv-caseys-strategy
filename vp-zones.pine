// © Saad_Pro

//@version=5
indicator("Simple Session Volume Profile with HVN Zones by Saad_Pro", shorttitle="SVP-HVN", overlay=true, max_boxes_count=500, max_lines_count=500, max_labels_count=500)

// --- USER INPUTS ---
session_input = input.session("0400-1600", "Trading Session")
hvn_threshold = input.int(2, "HVN Lookback (bins)", minval=1, group="HVN Settings")
zone_color_input = input.color(color.new(color.orange, 85), "HVN Zone Color", group="Colors")

// --- CORE CALCULATIONS ---
// 1. Session Detection
session_time = time(timeframe.period, session_input)
in_session = not na(session_time)
is_new_session = in_session and not in_session[1]

// Arrays to hold our profile data
var float[] vol_bins = array.new_float(0)
var float[] price_bins = array.new_float(0)
var box[] hvn_boxes = array.new_box(0)
var label[] hvn_labels = array.new_label(0)
var line[] profile_lines = array.new_line(0)
var int session_start_bar = na

// Clean up old objects and arrays on new session start
if is_new_session
    if array.size(hvn_boxes) > 0
        for b in hvn_boxes
            box.delete(b)
    if array.size(hvn_labels) > 0
        for l in hvn_labels
            label.delete(l)
    if array.size(profile_lines) > 0
        for l in profile_lines
            line.delete(l)
    array.clear(hvn_boxes)
    array.clear(hvn_labels)
    array.clear(profile_lines)
    array.clear(vol_bins)
    array.clear(price_bins)
    session_start_bar := bar_index

// 2. Fetch Lower Timeframe Data (1 minute resolution)
float[] lt_closes = request.security_lower_tf(syminfo.tickerid, "1", close)
float[] lt_vols = request.security_lower_tf(syminfo.tickerid, "1", volume)

// 3. Build Volume Profile incrementally during the session
if in_session and not na(lt_closes) and array.size(lt_closes) > 0
    float step = syminfo.mintick * 10 // Grouping size (10 ticks)
    
    for j = 0 to array.size(lt_closes) - 1
        float c = array.get(lt_closes, j)
        float v = nz(array.get(lt_vols, j))
        
        if not na(c)
            bool found = false
            if array.size(price_bins) > 0
                for i = 0 to array.size(price_bins) - 1
                    float bin_price = array.get(price_bins, i)
                    if c >= bin_price and c < bin_price + step
                        array.set(vol_bins, i, array.get(vol_bins, i) + v)
                        found := true
                        break
            
            if not found
                array.push(price_bins, math.floor(c / step) * step)
                array.push(vol_bins, v)

// 4. Drawing Logic (Executed only on the last visible bar to save resources)
if barstate.islast and array.size(vol_bins) > 0
    // Clean up previous real-time drawings before redrawing
    if array.size(hvn_boxes) > 0
        for b in hvn_boxes
            box.delete(b)
        for l in hvn_labels
            label.delete(l)
        for l in profile_lines
            line.delete(l)
        array.clear(hvn_boxes)
        array.clear(hvn_labels)
        array.clear(profile_lines)

    // Sort arrays (ascending by price) using index array
    int[] indices = array.sort_indices(price_bins)
    float[] sorted_prices = array.new_float(0)
    float[] sorted_vols = array.new_float(0)
    
    for i = 0 to array.size(indices) - 1
        int idx = array.get(indices, i)
        array.push(sorted_prices, array.get(price_bins, idx))
        array.push(sorted_vols, array.get(vol_bins, idx))
        
    float max_vol = array.max(sorted_vols)
    float step = syminfo.mintick * 10
    int left_edge = na(session_start_bar) ? bar_index - 50 : session_start_bar

    // Draw Profile Lines (Histogram)
    for i = 0 to array.size(sorted_prices) - 1
        float vol_at_price = array.get(sorted_vols, i)
        float price_at_bin = array.get(sorted_prices, i)
        
        if max_vol > 0
            int profile_width_bars = 40 // Defines how far the histogram stretches
            int vol_length = math.round((vol_at_price / max_vol) * profile_width_bars)
            
            if vol_length > 0
                // Sell profile (Red)
                array.push(profile_lines, line.new(left_edge, price_at_bin + step/2, 
                  left_edge + math.round(vol_length/2), price_at_bin + step/2, 
                  color=color.new(color.red, 40), width=4))
                
                // Buy profile (Green)
                array.push(profile_lines, line.new(left_edge + math.round(vol_length/2), price_at_bin + step/2, 
                  left_edge + vol_length, price_at_bin + step/2, 
                  color=color.new(color.lime, 40), width=4))

    // Find and Draw HVN Zones
    if array.size(sorted_prices) > hvn_threshold * 2
        for i = hvn_threshold to array.size(sorted_prices) - 1 - hvn_threshold
            float current_vol = array.get(sorted_vols, i)
            bool is_local_peak = true
            
            // Validate it against adjacent threshold bins
            for j = 1 to hvn_threshold
                if current_vol <= array.get(sorted_vols, i - j) or current_vol <= array.get(sorted_vols, i + j)
                    is_local_peak := false
                    break
            
            // Peak must be > 75% of the absolute max volume
            if is_local_peak and current_vol > max_vol * 0.75
                float hvn_top = array.get(sorted_prices, i + hvn_threshold) + step
                float hvn_bottom = array.get(sorted_prices, i - hvn_threshold)
                
                array.push(hvn_boxes, box.new(left_edge, hvn_top, bar_index + 15, hvn_bottom, 
                  bgcolor=zone_color_input, border_color=na))
                
                array.push(hvn_labels, label.new(bar_index + 15, hvn_top, text="HVN Zone", 
                  color=color.new(color.white, 100), style=label.style_label_down, 
                  textcolor=color.new(zone_color_input, 10), size=size.small))